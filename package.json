{
  "name": "claudegauge",
  "private": true,
  "version": "0.1.0",
  "description": "Claude Code and Codex usage dashboard for Windows",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"wait-on tcp:1420 && npm:dev:electron\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:vite && npm run build:electron",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.claudegauge.app",
    "productName": "ClaudeGauge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "signtoolOptions": {
        "sign": null
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
